# 百炼 / DashScope API Key
DASHSCOPE_API_KEY=sk-your-key-here

# 同声传译模型
TRANSLATE_MODEL=qwen-plus

# AI 总结 / 思维导图模型（可独立配置）
SUMMARY_MODEL=qwen-plus
MINDMAP_MODEL=qwen-plus

# 本地 ASR 模型: tiny / base / small / medium
WHISPER_MODEL=base

# TTS 音色
TTS_VOICE=longxiaochun_v3

# HuggingFace 镜像
HF_ENDPOINT=https://hf-mirror.com
