# 大模型厂商: dashscope / openai / deepseek / custom
LLM_PROVIDER=dashscope

# 当前厂商 API Key（也可用各厂商专用变量，见下方）
LLM_API_KEY=sk-your-key-here

# 自定义厂商 Base URL（非 custom 时可留空，使用预设）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 向后兼容：百炼 Key
DASHSCOPE_API_KEY=sk-your-key-here

# 可选：其他厂商 Key
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...

# 同声传译模型
TRANSLATE_MODEL=qwen-plus

# AI 总结 / 思维导图模型（可独立配置）
SUMMARY_MODEL=qwen-plus
MINDMAP_MODEL=qwen-plus

# 本地 ASR 模型: tiny / base / small / medium
WHISPER_MODEL=base

# TTS 音色
TTS_VOICE=longxiaochun_v3

# HuggingFace 镜像
HF_ENDPOINT=https://hf-mirror.com
